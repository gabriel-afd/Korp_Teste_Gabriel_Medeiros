services:

  sqlserver:
    image: mcr.microsoft.com/mssql/server:2022-latest
    container_name: korpErp-sqlserver
    environment:
      MSSQL_SA_PASSWORD: "Korp@2024!"
      ACCEPT_EULA: "Y"
    ports:
      - "1434:1433"
    volumes:
      - sqlserver_data:/var/opt/mssql
    healthcheck:
      test: ["CMD-SHELL", "/opt/mssql-tools18/bin/sqlcmd -S localhost -U sa -P 'Korp@2024!' -Q 'SELECT 1' -C -b"]
      interval: 10s
      timeout: 5s
      retries: 10

  rabbitmq:
    image: rabbitmq:management
    container_name: korpErp-rabbitmq
    ports:
      - "5672:5672"
      - "15672:15672"
    healthcheck:
      test: ["CMD", "rabbitmq-diagnostics", "ping"]
      interval: 10s
      timeout: 5s
      retries: 5

  estoque-api:
    build:
      context: .
      dockerfile: KorpERP/Dockerfile/Dockerfile
    container_name: korpErp-estoque
    ports:
      - "5001:8080"
    environment:
      - ASPNETCORE_ENVIRONMENT=Development
      - ConnectionStrings__DefaultConnection=Server=sqlserver;Database=EstoqueDb;User Id=sa;Password=Korp@2024!;TrustServerCertificate=True;
      - RabbitMQ__Host=rabbitmq
    depends_on:
      sqlserver:
        condition: service_healthy
      rabbitmq:
        condition: service_healthy

  faturamento-api:
    build:
      context: .
      dockerfile: Faturamento.Api/Dockerfile/Dockerfile
    container_name: korpErp-faturamento
    ports:
      - "5002:8080"
    environment:
      - ASPNETCORE_ENVIRONMENT=Development
      - ConnectionStrings__DefaultConnection=Server=sqlserver;Database=FaturamentoDb;User Id=sa;Password=Korp@2024!;TrustServerCertificate=True;
      - RabbitMQ__Host=rabbitmq
      - EstoqueApi__BaseUrl=http://estoque-api:8080
    depends_on:
      sqlserver:
        condition: service_healthy
      rabbitmq:
        condition: service_healthy

volumes:
  sqlserver_data: