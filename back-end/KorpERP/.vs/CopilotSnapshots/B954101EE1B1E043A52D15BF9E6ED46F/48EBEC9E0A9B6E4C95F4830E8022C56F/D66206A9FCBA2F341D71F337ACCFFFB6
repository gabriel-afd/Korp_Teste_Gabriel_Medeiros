FROM mcr.microsoft.com/dotnet/aspnet:8.0 AS base
WORKDIR /app
EXPOSE 8080

FROM mcr.microsoft.com/dotnet/sdk:8.0 AS build
WORKDIR /src

COPY ["Faturamento.Api/Faturamento.Api.csproj", "Faturamento.Api/"]
COPY ["Faturamento.Application/Faturamento.Application.csproj", "Faturamento.Application/"]
COPY ["Faturamento.Domain/Faturamento.Domain.csproj", "Faturamento.Domain/"]
COPY ["Faturamento.Infra.Data/Faturamento.Infra.Data.csproj", "Faturamento.Infra.Data/"]
COPY ["Faturamento.Infra.IoC/Faturamento.Infra.IoC.csproj", "Faturamento.Infra.IoC/"]
COPY ["Estoque.Application/Estoque.Application.csproj", "Estoque.Application/"]
COPY ["Estoque.Domain/Estoque.Domain.csproj", "Estoque.Domain/"]

RUN dotnet restore "Faturamento.Api/Faturamento.Api.csproj"

COPY . .
WORKDIR "/src/Faturamento.Api"
RUN dotnet publish -c Release -o /app/publish

FROM base AS final
WORKDIR /app
COPY --from=build /app/publish .
ENTRYPOINT ["dotnet", "Faturamento.Api.dll"]